# =============================================================================
# AgriBot Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# All variables are prefixed with AGRIBOT_ to avoid conflicts.

# --- Paths ---
# AGRIBOT_DATA_DIR=./data
# AGRIBOT_PDF_DIR=./data/pdfs
# AGRIBOT_INDEX_DIR=./data/indexes
# AGRIBOT_KG_DB_PATH=./data/knowledge_graph.db
# AGRIBOT_MODEL_PATH=./models/qwen3b.gguf

# --- LLM ---
# AGRIBOT_LLM_N_CTX=4096            # Context window size
# AGRIBOT_LLM_N_GPU_LAYERS=20       # GPU layers (RTX 3050 4GB)
# AGRIBOT_LLM_MAX_TOKENS=512        # Max tokens per answer
# AGRIBOT_LLM_TEMPERATURE=0.1       # Low = more deterministic

# --- Ingestion ---
# AGRIBOT_CHUNK_SIZE=600             # Max chunk size in characters
# AGRIBOT_CHUNK_OVERLAP=120          # Overlap between chunks
# AGRIBOT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval ---
# AGRIBOT_DENSE_TOP_K=15             # Dense retrieval candidates
# AGRIBOT_SPARSE_TOP_K=15            # BM25 retrieval candidates
# AGRIBOT_RERANK_TOP_N=5             # Final reranked results
# AGRIBOT_RERANK_THRESHOLD=0.15      # Min rerank score
# AGRIBOT_DENSE_WEIGHT=0.6           # Dense weight in RRF
# AGRIBOT_SPARSE_WEIGHT=0.4          # Sparse weight in RRF

# --- Agent ---
# AGRIBOT_MAX_RETRIES=2              # Max retrieval retries
# AGRIBOT_EVIDENCE_GRADE_THRESHOLD=0.5

# --- Voice ---
# AGRIBOT_WHISPER_MODEL_SIZE=base    # tiny/base/small/medium
# AGRIBOT_TTS_RATE=150               # TTS speaking rate (WPM)
# AGRIBOT_TTS_BENGALI_VOICE=         # System Bengali voice name (empty = auto)

# --- Noise Filtering ---
# AGRIBOT_HEADER_FOOTER_FREQ_THRESHOLD=0.5
# AGRIBOT_MIN_CHUNK_LENGTH=30
